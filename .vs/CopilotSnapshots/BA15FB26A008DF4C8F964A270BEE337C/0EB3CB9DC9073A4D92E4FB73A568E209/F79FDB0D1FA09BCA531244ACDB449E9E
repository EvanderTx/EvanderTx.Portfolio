<section id="experiencia" class="py-20 px-4 max-w-5xl mx-auto bg-indigo-500">
    <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-white mb-2 text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-500">
            Experiência Profissional
        </h2>
        <div class="h-1 w-20 bg-purple-500 mx-auto rounded-full mb-10"></div>
    </div>

    <div class="relative flex flex-col gap-4">
        <ExperienceCard Cargo="Programador Sénior (.Net C#)"
                        Empresa="Isabelinha Comercial"
                        Periodo="Actual"
                        Descricao="Desenvolvimento, implementação e manutenção de um sistema de gestão educacional para o ensino superior."
                        Responsabilidades="Responsabilidades1"
                        Tecnologias='new List<string> { "C#", ".NET Core", "ASP.NET MVC", "SQL Server", "Entity Framework", "REST APIs" }' 
                        DelayIndex="1"  />

        <ExperienceCard Cargo="Desenvolvedor Web & Designer Gráfico"
                        Empresa="Egate Gloud"
                        Periodo="Abril 2023 - Dezembro 2023"
                        Descricao="Desenvolvimento de websites e criação de peças gráficas para campanhas de marketing."
                        Responsabilidades="Responsabilidades2"
                        Tecnologias='new List<string> { "HTML5", "CSS3", "JavaScript", "WordPress", "Bootstrap" }' 
                        DelayIndex="2"  />

        <ExperienceCard Cargo="Programador (.Net C#)"
                        Empresa="Isabelinha Comercial"
                        Periodo="Março 2022 - Outubro 2022"
                        Descricao="Desenvolvimento de sistema de gestão de processos documentais internos."
                        Responsabilidades="Responsabilidades3"
                        Tecnologias='new List<string> { "C#", ".NET Core", "ASP.NET MVC", "SQL Server", "Entity Framework", }' 
                        DelayIndex="3"    />
    </div>
</section>

