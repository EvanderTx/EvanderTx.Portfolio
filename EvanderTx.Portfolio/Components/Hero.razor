@inject NavigationManager Nav


<!-- Hero Section - REESTRUTURADO COM ESPAÇO PARA FOTO -->
<section class="relative min-h-screen flex items-center justify-center pt-20 pb-20 overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-transparent to-transparent"></div>
    <!-- Grid pattern -->
    <div class="absolute inset-0 grid-pattern"></div>


    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        
            <!-- Coluna da Esquerda: Texto e Informações -->
            <div class="text-center lg:text-left order-2 lg:order-1">
                <!-- Badge -->
                <span class="inline-block mb-6 px-4 py-2 bg-card text-primary-light border border-primary/30 text-xs tracking-wider rounded-full">
                    Desenvolvedor .NET C# Full Stack
                </span>
          
                <!-- Main Title -->
                <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold mb-6 leading-tight outline-none">
                    <span class="gradient-text">Evander Teixeira</span>
                </h1>
          
                <!-- Description -->
                <p class="text-lg sm:text-xl text-muted max-w-xl mx-auto lg:mx-0 mb-8 leading-relaxed">
                    Sou um jovem desenvolvedor, curioso e aberto a novos desafios, buscando sempre
                    expandir os meus conhecimentos e apresentar os melhores resultados possíveis.
                </p>
          
                <!-- CTA Buttons -->
                <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 mb-8">
                    <a href="mailto:evanderteixeira@gmail.com" class="flex items-center gap-2 bg-primary hover:bg-primary-dark text-white px-8 py-3 rounded-md font-medium glow transition-colors duration-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                        </svg>
                        Contactar
                    </a>
                    <a href="https://github.com/EvanderTx" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 border border-border text-white hover:bg-card px-8 py-3 rounded-md font-medium transition-colors duration-200">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                        </svg>
                        GitHub
                    </a>
                </div>
          
                <!-- Contact Info -->
                <div class="flex flex-wrap items-center justify-center lg:justify-start gap-6 text-sm text-muted">
                    <div class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <span>Luanda, Angola</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                        </svg>
                        <a href="https://www.linkedin.com/in/evander-teixeira-148795196/" target="_blank">Evander Teixeira</a>
                    </div>
                    <div class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                        </svg>
                        <span>evanderteixeira@gmail.com</span>
                    </div>
                </div>
            </div>
        
            <!-- Coluna da Direita: Imagem do Perfil -->
            <div class="flex justify-center lg:justify-end order-1 lg:order-2">
                <div class="relative">
                    <!-- Círculo decorativo de fundo -->
                    <div class="absolute inset-0 bg-gradient-to-br from-primary/30 to-pink-500/30 rounded-full blur-3xl transform scale-110"></div>
            
                    <!-- Container da imagem -->
                    <div class="relative w-64 h-64 sm:w-80 sm:h-80 md:w-96 md:h-96 rounded-full overflow-hidden border-2 border-primary/30 profile-glow bg-card">

                        <img src="/images/evandertx2.png"
                             alt="Evander Teixeira"
                             class="w-full h-full object-cover"
                             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
              
                        <!-- Placeholder caso a imagem não carregue -->
                        <div class="hidden w-full h-full items-center justify-center bg-card text-muted flex-col gap-2">
                            <svg class="w-16 h-16 text-primary/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                            </svg>
                            <span class="text-sm">Sua foto aqui</span>
                        </div>
                    </div>
            
                    <!-- Elementos decorativos flutuantes -->
                    <div class="absolute -top-4 -right-4 w-20 h-20 bg-primary/20 rounded-full blur-xl"></div>
                    <div class="absolute -bottom-4 -left-4 w-16 h-16 bg-pink-500/20 rounded-full blur-xl"></div>
                </div>
            </div>
        
        </div>
      
        <!-- Scroll indicator - Ajustado para ficar mais abaixo -->
        <div class="absolute bottom-[-160px] left-1/2 transform -translate-x-1/2">
            <div class="w-6 h-10 border-2 border-border rounded-full flex justify-center pt-2">
                <div class="w-1.5 h-3 bg-primary rounded-full animate-bounce-slow"></div>
            </div>
        </div>
    </div>

</section>

