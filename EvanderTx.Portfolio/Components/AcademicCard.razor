<div class="bg-[#11161d] border border-white/5 rounded-2xl p-6 mb-4 reveal hover:border-purple-500/30 transition-all group">
    <div class="flex items-start gap-4">
        <div class="p-3 bg-purple-600/10 rounded-xl text-purple-400 group-hover:bg-purple-600/20 transition-colors">
            <i data-lucide="graduation-cap" class="w-6 h-6"></i>
        </div>

        <div class="flex-grow">
            <div class="flex justify-between items-start gap-2">
                <div>
                    <h3 class="text-white font-bold text-lg leading-tight">@Curso</h3>
                    <p class="text-purple-400 font-medium text-sm mt-1">@Instituicao</p>
                </div>
                <span class="px-3 py-1 bg-[#1a1f2e] border border-white/10 rounded-full text-gray-400 text-xs font-medium whitespace-nowrap">
                    @Ano
                </span>
            </div>
            <p class="text-gray-500 text-sm mt-3 leading-relaxed">@Descricao</p>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Curso { get; set; }
    [Parameter] public string Instituicao { get; set; }
    [Parameter] public string Ano { get; set; }
    [Parameter] public string Descricao { get; set; }
}