<div class="flex flex-col items-center justify-center p-6 bg-[#161b22]/50 border border-white/5 rounded-xl">
    <span class="text-3xl md:text-4xl font-bold text-purple-400 mb-1">@Valor</span>
    <span class="text-xs uppercase tracking-widest text-white">@Label</span>
</div>

@code {
    [Parameter] public string Valor { get; set; }
    [Parameter] public string Label { get; set; }
}