@inject NavigationManager Nav
@inject IJSRuntime JS

<!-- Header -->
<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 @(_headerClass)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <!-- Logo -->
            <a href="#" class="flex items-center gap-2">
                <span class="text-xl font-bold gradient-text">Evander Teixeira</span>
            </a>
        
            <!-- Desktop Navigation -->
            <nav class="hidden md:flex items-center gap-8">
                <a href="#sobre" class="text-sm text-muted hover:text-white transition-colors duration-200">Sobre</a>
                <a href="#experiencia" class="text-sm text-muted hover:text-white transition-colors duration-200">Experiência</a>
                <a href="#habilidades" class="text-sm text-muted hover:text-white transition-colors duration-200">Habilidades</a>
                <a href="#formacao" class="text-sm text-muted hover:text-white transition-colors duration-200">Formação</a>
                <a href="#contacto" class="px-4 py-2 border border-primary text-primary hover:bg-primary hover:text-white rounded-md transition-all duration-200 text-sm font-medium">
                    Contacto
                </a>
            </nav>
        
            <!-- Mobile Menu Button -->
            <button id="menuBtn" class="md:hidden text-white p-2" @onclick="ToggleMenu">
                <svg id="menuIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
                <svg id="closeIcon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
    </div>
    
    <!-- Mobile Menu -->
    <div id="mobileMenu" class="@(isMenuOpen?"open":"hidden")  mobile-menu md:hidden bg-card border-b border-border">
        <nav class="flex flex-col px-4 py-4 gap-4">
            <a @onclick="ToggleMenu" href="#sobre" class="text-muted hover:text-white transition-colors duration-200 py-2">Sobre</a>
            <a @onclick="ToggleMenu" href="#experiencia" class="text-muted hover:text-white transition-colors duration-200 py-2">Experiência</a>
            <a @onclick="ToggleMenu" href="#habilidades" class="text-muted hover:text-white transition-colors duration-200 py-2">Habilidades</a>
            <a @onclick="ToggleMenu" href="#formacao" class="text-muted hover:text-white transition-colors duration-200 py-2">Formação</a>
            <a @onclick="ToggleMenu" href="#contacto" class="px-4 py-2 border border-primary text-primary hover:bg-primary hover:text-white rounded-md transition-all duration-200 text-sm font-medium text-center">
                Contacto
            </a>
        </nav>
    </div>
</header>


@code {
    private bool isMenuOpen = false;
    private bool _isScrolled = false;
    private void ToggleMenu() => isMenuOpen = !isMenuOpen;

    // Define as classes dinamicamente baseadas no estado
    private string _headerClass => _isScrolled
        ? "bg-background/90 backdrop-blur-md border-b border-border"
        : "bg-transparent";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var dotNetObjRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("setupScrollListener", dotNetObjRef);


            // Aguarda um pequeno instante para garantir que o DOM e scripts externos carregaram
            await Task.Delay(100);
            try
            {
                await JS.InvokeVoidAsync("window.initPortfolio");
            }
            catch (Exception ex)
            {
                // Isso evita que o erro "trave" a aplicação e mostre a barra de erro
                Console.WriteLine("Aguardando scripts: " + ex.Message);
            }
        }
    }

    [JSInvokable]
    public void OnWindowScroll(double scrollY)
    {
        var shouldBeScrolled = scrollY > 50;
        
        // Só atualiza o estado se houver mudança (performance)
        if (shouldBeScrolled != _isScrolled)
        {
            _isScrolled = shouldBeScrolled;
            StateHasChanged();
        }
    }
}